    {
      "parameters": {
        "jsCode": "const item = $input.first();\n\nconst { date, time } = item.json;\n\nif (!date || !time) {\n  throw new Error(`Missing required fields. date=${date}, time=${time}`);\n}\n\n// Parse time\nlet hours, minutes;\n\nif (time.includes(\"AM\") || time.includes(\"PM\")) {\n  const [clock, period] = time.split(\" \");\n  [hours, minutes] = clock.split(\":\").map(Number);\n\n  if (period === \"PM\" && hours !== 12) hours += 12;\n  if (period === \"AM\" && hours === 12) hours = 0;\n} else {\n  [hours, minutes] = time.split(\":\").map(Number);\n}\n\n// Build local Date\nconst start = new Date(`${date}T${String(hours).padStart(2, \"0\")}:${String(minutes).padStart(2, \"0\")}:00`);\n\nconst end = new Date(start);\nend.setHours(end.getHours() + 1);\n\nreturn [{\n  json: {\n    ...item.json,\n    start: start.toISOString(),\n    end: end.toISOString()\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
